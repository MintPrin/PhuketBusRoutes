{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/((?!data/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "phuketbusroutes.mintprin.com" }],
      "destination": "https://phuketbusroutes.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.phuketbusroutes.com" }],
      "destination": "https://phuketbusroutes.com/:path*",
      "permanent": true
    }
  ]
}
